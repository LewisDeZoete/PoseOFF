feeder: feeders.ntu_rgb_d.Feeder
feeder_args:
  data_paths: {'CS': './data/ntu/aligned_data/NTU60_CS-pose_aligned.npz', 'CV': './data/ntu/aligned_data/NTU60_CV-pose_aligned.npz'}
