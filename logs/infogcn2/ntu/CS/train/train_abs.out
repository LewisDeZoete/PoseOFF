feeder: feeders.ntu_rgb_d.Feeder
feeder_args:
  data_paths: {'CS': './data/ntu/aligned_data/NTU60_CS-flowpose_aligned.npz', 'CV': './data/ntu/aligned_data/NTU60_CV-flowpose_aligned.npz'}
  label_path: ./data/ntu/statistics/ntu-rgbd-annotations.yaml
  p_interval: [0.5, 1]
  random_choose: True
  random_shift: True
  window_size: 64
  random_move: True
  random_rot: True
  average_flow: False
  absolute_flow: {'window_mean': True}
  no_flow: False
extractor:
  preprocessed: True
  pose: {'weights': 'pretrained_models/yolo11x-pose.pt'}
  flow: {'weights': 'pretrained_models/raft_large.pt', 'imsize': [1080, 1920], 'minibatch_size': 3, 'dilation': 1}
  flowpose: {'window_size': 5, 'threshold': 0.05, 'loop': False, 'norm': False, 'match_pose': False, 'ntu': True}
model: model.infogcn2.sode.SODE
model_args:
  num_class: 60
  num_point: 25
  num_person: 2
  graph: graph.ntu_rgb_d.Graph
  pose_channels: 3
  flow_channels: 1
  embed_channels: 64
  num_head: 3
  ode_method: euler
  depth: 4
  device: 0
  T: 64
  n_step: 3
  SAGC_proj: True
  num_cls: 10
  n_sample: 1
  backbone: transformer
  cnn: False
  use_mask: True
ignore_weights: []
phase: train
optim:
  base_lr: 0.1
  nesterov: True
  weight_decay: 0.0003
  step: [50, 60]
  gamma: 0.1
lambda_1: 1
lambda_2: 0.1
lambda_3: 0.001
lambda_4: 0.0
lambda_5: 0.0
num_epoch: 70
device: 0
batch_size: 256
forward_batch_size: 128
test_batch_size: 256
half: False
checkpoint_freq: 10
save_location: ./results/ntu/
dataset: ntu
model_type: abs
evaluation: CS
run_name: ntu_CS_abs
description: train ntu {evaluation} {model_type}
data_path_overwrite: /var/tmp/jobfs/data
verbose: True
