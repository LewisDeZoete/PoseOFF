Data path: /var/tmp/jobfs/data/ntu_CV-flowpose_D3_aligned.npz
Dataset: ntu
Evaluation: CV
Flow embedding: cnn
feeder: feeders.ntu_rgb_d.Feeder
feeder_args:
  data_paths: {'CS': './data/ntu/aligned_data/ntu_CS-flowpose_D3_aligned.npz', 'CV': './data/ntu/aligned_data/ntu_CV-flowpose_D3_aligned.npz'}
  label_path: ./data/ntu/statistics/ntu_rgbd-annotations.yaml
  p_interval: [0.5, 1]
  random_choose: True
  random_shift: True
  window_size: 64
  random_move: True
  random_rot: True
  average_flow: False
  absolute_flow: False
  no_flow: False
  no_Z: False
extractor:
  preprocessed: True
  pose: {'weights': 'pretrained_models/yolo11x-pose.pt'}
  flow: {'weights': 'pretrained_models/raft_large.pt', 'imsize': [1080, 1920], 'minibatch_size': 3}
  flowpose: {'window_size': 5, 'threshold': 0.05, 'loop': False, 'norm': False, 'match_pose': False, 'ntu': True, 'dilation': 3}
model: models.infogcn2.sode.SODE
model_args:
  num_class: 60
  num_point: 25
  num_person: 2
  graph: graph.ntu_rgb_d.Graph
  pose_channels: 3
  flow_channels: 50
  embed_channels: 64
  num_head: 3
  ode_method: euler
  depth: 4
  device: 0
  T: 64
  n_step: 3
  SAGC_proj: True
  num_cls: 10
  n_sample: 1
  backbone: transformer
  cnn: True
  use_mask: True
ignore_weights: []
phase: train
optimiser: torch.optim.SGD
optim_params:
  lr: 0.1
  momentum: 0.9
  weight_decay: 0.0003
  nesterov: True
lambda_1: 1
lambda_2: 0.1
lambda_3: 0.001
lambda_4: 0.0
lambda_5: 0.0
scheduler: torch.optim.lr_scheduler.MultiStepLR
scheduler_params:
  milestones: [50, 60]
  gamma: 0.1
training_function: training.train_infogcn.train_network
testing_function: training.eval_infogcn.eval_network
num_epoch: 70
device: 0
batch_size: 256
forward_batch_size: 128
test_batch_size: 256
half: False
checkpoint_freq: 10
save_location: ./results/infogcn2/ntu/
